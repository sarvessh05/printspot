    # ==========================================
    # 🛠️ Supabase Configuration
    # ==========================================
    SUPABASE_URL=YOUR_SUPABASE_URL
    SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
    SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

    # Frontends (Vite) also use these names with VITE_ prefix
    VITE_SUPABASE_URL=YOUR_SUPABASE_URL
    VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

    # ==========================================
    # 🖥️ Kiosk Identity & Security
    # ==========================================
    KIOSK_ID=KIOSK_PUNE_001
    KIOSK_TOKEN=YOUR_SECRET_TOKEN
    ADMIN_PASSWORD=Sahil@123
    ADMIN_MASTER_PASSWORD=admin_secret_987

    # ==========================================
    # 💳 Payment Configuration (Razorpay)
    # ==========================================
    RAZORPAY_KEY_ID=YOUR_RAZORPAY_KEY_ID
    RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_KEY_SECRET

    # ==========================================
    # 🖨️ Hardware & Network Configuration
    # ==========================================
    PRINTER_IP=192.168.1.58
    # Printers names (exactly as in Windows Control Panel)
    PRINTER_BW=HP LaserJet BW
    PRINTER_BW_DUPLEX=HP LaserJet BW Duplex
    PRINTER_COLOR=HP LaserJet Color
    PRINTER_COLOR_DUPLEX=HP LaserJet Color Duplex

    # Admin API IP (Cloud)
    EC2_IP=http://localhost:8083

    # SumatraPDF path (optional if in Windows PATH)
    SUMATRA_PDF_PATH=C:\Program Files\SumatraPDF\SumatraPDF.exe

    # ==========================================
    # 🔔 Notifications (Telegram Bot)
    # ==========================================
    TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
    TELEGRAM_CHAT_ID=YOUR_CHAT_ID

    # ==========================================
    # ⚙️ Dev Settings
    # ==========================================
    DEBUG=True
    MOCK_PRINTER=False
    ALLOWED_ORIGINS=*


